{
  "name": "lensify-backend",
  "version": "1.0.0",
  "description": "Backend API for Lensify.co camera rental platform",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "db:migrate": "npx prisma migrate dev --name init",
